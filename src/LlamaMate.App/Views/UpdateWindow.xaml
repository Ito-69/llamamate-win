<Window x:Class="LlamaMate.App.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LlamaMate Update"
        Height="300" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Assets/llama.ico">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Update Available" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />

        <StackPanel Grid.Row="1">
            <TextBlock x:Name="VersionInfo" Text="" FontSize="14" Margin="0,0,0,8" />
            <Border BorderBrush="#DDD" BorderThickness="1" Padding="8" CornerRadius="4" Background="#F9F9F9" MinHeight="80">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ReleaseNotes" Text="" TextWrapping="Wrap" />
                </ScrollViewer>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="DownloadButton" Content="Download &amp; Install" Click="DownloadAndInstall" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" />
            <Button x:Name="SkipButton" Content="Skip" Click="Skip_Click" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
            <Button x:Name="RemindLaterButton" Content="Remind Later" Click="RemindLater_Click" Style="{StaticResource SecondaryButton}" />
        </StackPanel>
    </Grid>
</Window>
