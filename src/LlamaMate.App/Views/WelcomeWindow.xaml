<Window x:Class="LlamaMate.App.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to LlamaMate"
        Height="380" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        ShowInTaskbar="True">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Welcome to LlamaMate" FontSize="22" FontWeight="Bold" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,16" LineHeight="22">
            LlamaMate will download and install the following components to get you started:
            <LineBreak /><LineBreak />
            <Run FontWeight="SemiBold">&#8226; llama.cpp server</Run> &#8212; the inference engine
            <LineBreak />
            <Run FontWeight="SemiBold">&#8226; Qwen2.5 1.5B Q4_K_M (~1 GB)</Run> &#8212; a lightweight test model
            <LineBreak /><LineBreak />
            Click <Run FontWeight="SemiBold">"Install"</Run> to begin. This may take a few minutes depending on your internet speed.
        </TextBlock>

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" Padding="12" CornerRadius="4" Background="#FFF8E1" Margin="0,0,0,16">
            <TextBlock x:Name="StatusText" Text="Ready to install" Foreground="#666" FontSize="13" />
        </Border>

        <StackPanel Grid.Row="3" VerticalAlignment="Center" Margin="0,0,0,16">
            <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100" Value="0" />
            <TextBlock x:Name="ProgressLabel" Text="" Foreground="#999" FontSize="11" Margin="0,4,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="InstallButton" Content="Install" Click="Install_Click" Style="{StaticResource PrimaryButton}" Width="100" Height="32" />
            <Button x:Name="SkipButton" Content="Skip" Click="Skip_Click" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Width="80" Height="32" />
        </StackPanel>
    </Grid>
</Window>
